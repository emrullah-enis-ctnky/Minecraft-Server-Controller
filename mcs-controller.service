[Unit]
Description=Minecraft Server Web Controller
After=network.target

[Service]
Type=simple
User=enis27
WorkingDirectory=~/mc_server/controller
ExecStart=/usr/bin/node ~/mc_server/controller/server.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
